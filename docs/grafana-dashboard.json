{
  "dashboard": {
    "title": "LookAI Dashboard",
    "tags": ["lookai", "local", "agent"],
    "timezone": "browser",
    "schemaVersion": 36,
    "refresh": "5s",
    "panels": [
      {
        "id": 1,
        "title": "Context Usage",
        "type": "gauge",
        "targets": [
          {
            "expr": "lookai_context_tokens / lookai_context_limit",
            "legendFormat": "Context %"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "min": 0,
            "max": 1,
            "thresholds": {
              "steps": [
                { "color": "green", "value": 0 },
                { "color": "yellow", "value": 0.6 },
                { "color": "red", "value": 0.85 }
              ]
            }
          }
        },
        "gridPos": { "h": 8, "w": 6, "x": 0, "y": 0 }
      },
      {
        "id": 2,
        "title": "Active Model",
        "type": "stat",
        "targets": [
          {
            "expr": "lookai_active_model",
            "legendFormat": "{{model}}"
          }
        ],
        "gridPos": { "h": 8, "w": 6, "x": 6, "y": 0 }
      },
      {
        "id": 3,
        "title": "Turn Count",
        "type": "stat",
        "targets": [
          {
            "expr": "lookai_turn_count",
            "legendFormat": "Turns"
          }
        ],
        "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 }
      },
      {
        "id": 4,
        "title": "Tool Use Latency",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(lookai_tool_latency_sum[1m]) / rate(lookai_tool_latency_count[1m])",
            "legendFormat": "{{tool}}"
          }
        ],
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 }
      },
      {
        "id": 5,
        "title": "Session Status",
        "type": "table",
        "targets": [
          {
            "expr": "lookai_session_status",
            "format": "table"
          }
        ],
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 }
      },
      {
        "id": 6,
        "title": "Memory (VRAM)",
        "type": "gauge",
        "targets": [
          {
            "expr": "lookai_vram_used / lookai_vram_total",
            "legendFormat": "VRAM %"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "min": 0,
            "max": 1,
            "thresholds": {
              "steps": [
                { "color": "green", "value": 0 },
                { "color": "yellow", "value": 0.7 },
                { "color": "red", "value": 0.9 }
              ]
            }
          }
        },
        "gridPos": { "h": 8, "w": 6, "x": 0, "y": 16 }
      },
      {
        "id": 7,
        "title": "Eval Score",
        "type": "stat",
        "targets": [
          {
            "expr": "lookai_eval_score",
            "legendFormat": "Score"
          }
        ],
        "gridPos": { "h": 8, "w": 6, "x": 6, "y": 16 }
      }
    ]
  }
}
