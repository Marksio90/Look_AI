{
  "name": "@lookai/cli",
  "version": "0.0.1",
  "type": "module",
  "bin": {
    "lookai": "./dist/main.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "eslint src/**/*.ts",
    "clean": "rm -rf dist",
    "start": "node ./dist/main.js"
  },
  "dependencies": {
    "@lookai/shared": "workspace:*",
    "@lookai/llm": "workspace:*",
    "@lookai/tools": "workspace:*",
    "@lookai/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
