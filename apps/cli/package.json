{
  "name": "@lookai/cli",
  "version": "0.0.1",
  "type": "module",
  "bin": {
    "lookai": "./dist/main.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && cp src/main.tsx dist/main.js 2>/dev/null || true",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "eslint src/**/*.{ts,tsx}",
    "clean": "rm -rf dist",
    "start": "node ./dist/main.js"
  },
  "dependencies": {
    "@lookai/shared": "workspace:*",
    "@lookai/llm": "workspace:*",
    "@lookai/tools": "workspace:*",
    "@lookai/core": "workspace:*",
    "@lookai/security": "workspace:*",
    "@lookai/context": "workspace:*",
    "@lookai/memory": "workspace:*",
    "ink": "^7.0.6",
    "react": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "@types/react": "^19.2.17",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
