{
  "name": "@lookai/ide-vscode",
  "displayName": "LookAI",
  "description": "LookAI IDE extension — inline diff and agent integration",
  "version": "0.0.1",
  "publisher": "lookai",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Machine Learning", "Programming Languages", "Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "lookai.startChat",
        "title": "Start LookAI Chat",
        "category": "LookAI"
      },
      {
        "command": "lookai.acceptDiff",
        "title": "Accept Diff",
        "category": "LookAI",
        "icon": "$(check)"
      },
      {
        "command": "lookai.rejectDiff",
        "title": "Reject Diff",
        "category": "LookAI",
        "icon": "$(x)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "lookai.startChat",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src/**/*.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
